@page "/events"
@using EventEase.Models

<h2>Events</h2>

<Virtualize Items="Events" Context="ev">
    <EventCard Event="ev" />
</Virtualize>

<div class="event-list-item">
    <h3>@ev.Title</h3>
    <NavLink href="/events/@ev.Id">View Details</NavLink>
</div>

@code {
    private List<EventModel> Events = new()
    {
        new EventModel { Id = 1, Title = "Blue Ridge Tech Meetup" },
        new EventModel { Id = 2, Title = "EventEase Launch Party" }
    };
}
