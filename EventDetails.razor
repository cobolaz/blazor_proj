@page "/events/{id:int}"
@using EventEase.Models

<h2>Event Details</h2>

@if (Event is null)
{
    <p>Event not found.</p>
    <NavLink href="/events">Back to Events</NavLink>
    return;
}
else
{
    <h3>@Event.Title</h3>
    <p>@Event.Description</p>
    <p><strong>Date:</strong> @Event.Date.ToShortDateString()</p>
    <p><strong>Location:</strong> @Event.Location</p>

    <NavLink href="/events/@Event.Id/register">Register</NavLink>
}

@code {
    [Parameter] public int Id { get; set; }

    private EventModel? Event;

    protected override void OnInitialized()
    {
        // Mock lookup
        var events = new List<EventModel>
        {
            new EventModel { Id = 1, Title = "Sedona Tech Meetup", Description = "A gathering of developers." },
            new EventModel { Id = 2, Title = "EventEase Launch Party", Description = "Celebrating the milestone." }
        };

        Event = events.FirstOrDefault(e => e.Id == Id);
    }
}
